# RMIT Connect Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment (development/production)
FLASK_ENV=development

# Security (REQUIRED - generate a new secret key for production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Email Configuration (REQUIRED for user authentication)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Legacy SMTP (for fallback - same as MAIL_* above)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Instructions:
# 1. For Gmail: 
#    - Enable 2-factor authentication
#    - Generate an App Password (not your regular password)
#    - Use the App Password in SMTP_PASSWORD and MAIL_PASSWORD
#
# 2. For other providers:
#    - Update SMTP_SERVER and SMTP_PORT accordingly
#    - Use your regular email credentials
#
# 3. To use this file:
#    - Rename to .env (remove .example)
#    - Install python-dotenv: pip install python-dotenv
#    - Load in your app with: from dotenv import load_dotenv; load_dotenv()
