# Production Environment Variables for Render.com
# Copy these to your Render.com service's Environment Variables section

# Flask Configuration
FLASK_ENV=production
SESSION_SECRET=your-super-secure-session-secret-key-for-production-change-this

# Database (Render.com will provide PostgreSQL URL)
DATABASE_URL=postgresql://username:password@hostname:port/database

# Email Configuration (Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-real-email@gmail.com
SMTP_PASSWORD=your-real-gmail-app-password

# Flask-Mail Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-real-email@gmail.com
MAIL_PASSWORD=your-real-gmail-app-password
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=your-real-email@gmail.com

# Security Settings
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=3600

# Instructions for Render.com:
# 1. Go to your Render.com service dashboard
# 2. Click on "Environment" tab
# 3. Add each variable above (without the # comments)
# 4. Replace placeholder values with real ones:
#    - SESSION_SECRET: Generate a long random string
#    - SMTP/MAIL credentials: Your real Gmail app password
#    - DATABASE_URL: Render will auto-populate this for PostgreSQL
# 5. Save and redeploy your service
